diff --git a/CMakeLists.txt b/CMakeLists.txt
index 4f37003..cb31b25 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -24,14 +24,34 @@ enable_language(ASM)
 # set global cflags and cxxflags
 set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -fcolor-diagnostics -fPIC -Wno-attributes")
 set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fcolor-diagnostics -fPIC -Wno-attributes")
-# static link (may need some patches)
-#set(CMAKE_EXE_LINKER_FLAGS "-static")
+
+# IMPORTANT (aarch64 host builds):
+# We are linking Android-target binaries with NDK clang + libc++_static.
+# Ensure we get a full C++ runtime (new/delete, __cxa_*, typeinfo).
+#
+# 1) Never use -static-libstdc++ here (it's for libstdc++ and breaks the runtime selection).
+# 2) Always link c++abi/unwind explicitly, because in this standalone setup the toolchain
+#    sometimes doesn't pull them in automatically when doing a mostly-static link.
+foreach(_f CMAKE_EXE_LINKER_FLAGS CMAKE_SHARED_LINKER_FLAGS CMAKE_MODULE_LINKER_FLAGS)
+  if(DEFINED ${_f})
+    string(REPLACE "-static-libstdc++" "" ${_f} "${${_f}}")
+  endif()
+endforeach()
+
+# Provide C++ runtime pieces explicitly.
+# NOTE: link order matters; keep these at the end.
+set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -lc++abi -lunwind")
+set(CMAKE_SHARED_LINKER_FLAGS "${CMAKE_SHARED_LINKER_FLAGS} -lc++abi -lunwind")
+set(CMAKE_MODULE_LINKER_FLAGS "${CMAKE_MODULE_LINKER_FLAGS} -lc++abi -lunwind")
 
 # platform tools version
 # see the patches/other/platform_tools_version.h
 set(TOOLS_VERSION 35.0.2)
 set(SRC ${PROJECT_SOURCE_DIR}/src)
 
+# Make Abseil headers visible to consumers like protobuf (which includes absl/*).
+include_directories(${SRC}/abseil-cpp)
+
 # 64-bit off_t for lseek.
 add_definitions(-D_FILE_OFFSET_BITS=64)
 
@@ -82,10 +102,21 @@ add_subdirectory(src/googletest EXCLUDE_FROM_ALL)
 add_subdirectory(src/tinyxml2 EXCLUDE_FROM_ALL)
 
 # building sdk-tools
+#
+# When building a single target (via ninja <target>), we still need the CMake
+# generate step to succeed. Newer AOSP tags may move files, causing unrelated
+# modules (adb/dexdump/etc) to fail configure. To keep iteration practical,
+# allow skipping platform-tools/others by toggling SDKTOOLS_MINIMAL.
+option(SDKTOOLS_MINIMAL "Skip platform-tools/others (keep libs + build-tools)" OFF)
+
+# aapt2 (and other build-tools) depend on libs from lib/.
 add_subdirectory(lib)
 add_subdirectory(build-tools)
-add_subdirectory(platform-tools)
-add_subdirectory(others)
+
+if(NOT SDKTOOLS_MINIMAL)
+    add_subdirectory(platform-tools)
+    add_subdirectory(others)
+endif()
 
 # creating source tarballs
 set(CPACK_PACKAGE_DIRECTORY ${PROJECT_SOURCE_DIR}/pack)
